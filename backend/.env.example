# Project Core Config
PROJECT_NAME="AgriVision AI"
API_V1_STR="/api/v1"

# Database Configuration
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/agrivision"

# Authentication (Supabase)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-here"
SUPABASE_JWT_ALGORITHM="HS256"

# Cloudflare R2 / S3 Storage
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_ENDPOINT_URL="https://your-r2-endpoint-url.r2.cloudflarestorage.com"
R2_BUCKET_NAME="agrivision-images"

# Modal ML Inference Serverless Endpoint
MODAL_API_URL="https://your-modal-app-name.modal.run"
CONFIDENCE_THRESHOLD=0.60
